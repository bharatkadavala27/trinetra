# ---------------------------------------------------------
# BACKEND ENVIRONMENT VARIABLES (PRODUCTION EXAMPLE)
# ---------------------------------------------------------

# MongoDB Connection
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/dbname

# Server Port
PORT=4597

# Environment (development or production)
NODE_ENV=production

# JWT Secret for Auth Tokens
JWT_SECRET=your_super_secret_key_change_this

# ---------------------------------------------------------
# SOCIAL OAUTH KEYS
# ---------------------------------------------------------

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ---------------------------------------------------------
# NOTIFICATION & OTP SERVICES
# ---------------------------------------------------------

# Email (SMTP)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# SMS (MSG91 Example)
SMS_API_KEY=your_msg91_auth_key
SMS_TEMPLATE_ID=your_msg91_otp_template_id

# WhatsApp (Meta WABA Example)
WABA_TOKEN=your_meta_system_user_token
WABA_PHONE_ID=your_whatsapp_phone_number_id

# ---------------------------------------------------------
# FIREBASE CLOUD MESSAGING (PUSH)
# ---------------------------------------------------------
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@xxxxx.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Key-Here\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------
# OTHER CONFIGS
# ---------------------------------------------------------
FRONTEND_URL=http://localhost:5173
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
